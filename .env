# Data source: 'mock' (local dev) or 'google_sheets' (production)
DATA_SOURCE=google_sheets

# Google Sheets Apps Script Web App URL
GOOGLE_SHEETS_ENDPOINT=https://script.google.com/macros/s/AKfycbzM1UqdOeObHC-6VfSPiXHaaRyk4rcgV8YsE866hLo3T_SwFmoo4sdZ5HEQi0RQngV2/exec

# Auto-refresh interval in milliseconds (default 60s)
REFRESH_INTERVAL_MS=60000

# Enable auto-refresh polling by default
NEXT_PUBLIC_ENABLE_AUTO_REFRESH=true

# Optional: separate API backend URL
NEXT_PUBLIC_API_URL=
